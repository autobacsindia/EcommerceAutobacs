# =============================================================================
# AUTOBACS INDIA - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# IMPORTANT: 
# 1. NEVER commit actual .env files with real secrets to Git
# 2. Copy this file to .env and fill in your values
# 3. For production, use Railway dashboard environment variables
# =============================================================================

# ── MongoDB Configuration ────────────────────────────────────────────────────
# Get from MongoDB Atlas: https://cloud.mongodb.com/
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/autobacs?retryWrites=true&w=majority

# TLS Configuration (MUST be true in production)
MONGO_TLS=true
MONGO_TLS_ALLOW_INVALID_CERTIFICATES=false
MONGO_TLS_ALLOW_INVALID_HOSTNAMES=false

# MongoDB Atlas API (for automatic IP whitelist management)
# Get from: MongoDB Atlas > Organization Settings > Access Manager > API Keys
MONGODB_ATLAS_PUBLIC_API_KEY=your_atlas_public_key
MONGODB_ATLAS_PRIVATE_API_KEY=your_atlas_private_key
MONGODB_ATLAS_PROJECT_ID=your_project_id
MONGODB_ATLAS_CLUSTER_NAME=Cluster0

# ── JWT Configuration ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be at least 64 characters
JWT_SECRET=your_jwt_secret_at_least_64_characters_long_use_crypto_random_bytes

# Token expiration
JWT_EXPIRE=30m
JWT_ADMIN_EXPIRE=15m

# ── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL for CORS ────────────────────────────────────────────────────
# Set FRONTEND_URL to your Cloudflare-proxied domain (NOT the raw Railway URL).
# The Railway .railway.app URL must also be included in FRONTEND_URLS so Railway
# health checks and internal routing continue to work during Cloudflare setup.
FRONTEND_URL=https://ecommerceautobacs-production-8ff6.up.railway.app
FRONTEND_URLS=https://autobacsindia.com,https://www.autobacsindia.com

# ── Cloudflare Configuration ──────────────────────────────────────────────────
# Set to true once Cloudflare proxy is live in front of this backend.
# Used to enforce CF-Connecting-IP as the authoritative real-IP source.
CLOUDFLARE_PROXY_ENABLED=true

# (WordPress/WooCommerce removed — data now lives entirely in MongoDB)

# ── Rate Limiting Configuration ──────────────────────────────────────────────
REGISTER_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_MAX=10
FAILED_LOGIN_RATE_LIMIT_MAX=5

# ── Elasticsearch (Optional) ─────────────────────────────────────────────────
# IMPORTANT: 
# - Set ELASTICSEARCH_ENABLED=false if not using Elasticsearch
# - NEVER use localhost in production - use cloud Elasticsearch service
# - Recommended: Elastic Cloud, AWS Elasticsearch, or self-hosted cluster
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_NODE=https://your-cluster.us-east-1.aws.elastic-cloud.com:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password
ELASTICSEARCH_RETRY_TIMEOUT=5000
ELASTICSEARCH_LOG_LEVEL=warn

# ── Google Maps API ──────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_CLIENT_KEY=your_google_maps_client_key
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key
GOOGLE_MAPS_REGION=IN
GOOGLE_MAPS_LANGUAGE=en

# ── Location Service Configuration ───────────────────────────────────────────
SESSION_LOCATION_EXPIRY=7
GEOCODING_CACHE_DURATION=30
MAX_ADDRESS_SEARCH_RESULTS=5
DEFAULT_LOCATION_RADIUS=50000

# ── Delivery Settings ────────────────────────────────────────────────────────
WAREHOUSE_PROCESSING_DAYS=1
EXCLUDE_SUNDAYS=true
DELIVERY_ESTIMATE_BUFFER=0

# ── Inventory Settings ───────────────────────────────────────────────────────
STOCK_RESERVATION_TIMEOUT=24
LOW_STOCK_THRESHOLD=5
ENABLE_SPLIT_SHIPMENTS=false
STOCK_SYNC_FREQUENCY=3600

# ── Email Notifications (SendGrid) ───────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your Company Name

# ── SMS Notifications (Twilio) ───────────────────────────────────────────────
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# ── Notification Settings ────────────────────────────────────────────────────
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=1000
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# ── Razorpay Payment Gateway ─────────────────────────────────────────────────
# IMPORTANT: Use LIVE keys for production (rzp_live_*)
# Get from: https://dashboard.razorpay.com/app/keys
# TEST keys: rzp_test_xxxxx
# LIVE keys: rzp_live_xxxxx
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# CRITICAL: Webhook secret for HMAC-SHA256 signature verification.
# Get from: Razorpay Dashboard → Account & Settings → Webhooks → (your webhook) → Secret
# Without this, ALL incoming webhooks will be rejected with HTTP 500.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

# ── Facebook OAuth ───────────────────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# ── Cloudinary (Image Storage) ───────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Redis (Caching & Sessions) ───────────────────────────────────────────────
# Get from: Redis provider (Upstash, Railway, etc.)
REDIS_URL=redis://:your_redis_password@your_redis_host:your_redis_port

# ── Sentry (Error Monitoring) ────────────────────────────────────────────────
# Get from: https://sentry.io/ → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Set to your git tag / package version for release tracking in Sentry
# SENTRY_RELEASE=1.0.0

# ── Alerting (P1 Incident Notifications) ─────────────────────────────────────
# Slack: Settings → Apps → Incoming Webhooks → Add to Slack
# All 5xx errors in production fire a deduplicated Slack alert (max once per 5 min per error type)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Cache Configuration (Optional) ───────────────────────────────────────────
CACHE_VERSION=v1
CACHE_WARMUP_ENABLED=false
REGION_ID=default

# ── Railway Deployment (Auto-set by Railway) ─────────────────────────────────
# DO NOT SET MANUALLY - Railway sets these automatically
# RAILWAY_PUBLIC_URL=
# RAILWAY_DEPLOYMENT_ID=
