# =============================================================================
# AUTOBACS E-COMMERCE PLATFORM - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# 
# IMPORTANT: This is a template file. Copy this to .env and fill in actual values.
# 
# SECURITY WARNING:
# - NEVER commit the actual .env file to version control
# - Keep API keys and secrets confidential
# - Rotate credentials regularly (every 90 days recommended)
# - Use different keys for development and production
#
# =============================================================================

# =============================================================================
# MONGODB CONFIGURATION
# =============================================================================
# MongoDB connection string
# Local: mongodb://localhost:27017/autobacs
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/autobacs
MONGO_URI=mongodb://localhost:27017/autobacs

# SSL/TLS Configuration Options
MONGO_TLS=false
MONGO_TLS_ALLOW_INVALID_CERTIFICATES=true

# MongoDB Atlas API Credentials (for automatic IP whitelist management)
# Get these from: https://cloud.mongodb.com/v2#/account/publicApi
MONGODB_ATLAS_PUBLIC_API_KEY=your_atlas_public_key_here
MONGODB_ATLAS_PRIVATE_API_KEY=your_atlas_private_key_here
MONGODB_ATLAS_PROJECT_ID=your_project_id_here
MONGODB_ATLAS_CLUSTER_NAME=Cluster0

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Secret key for JWT token signing (MUST be changed in production)
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Server port
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# =============================================================================
# WORDPRESS API CONFIGURATION
# =============================================================================
# WooCommerce REST API credentials for product import
# Get from: WordPress Admin → WooCommerce → Settings → Advanced → REST API
WORDPRESS_SITE_URL=https://your-wordpress-site.com/
WORDPRESS_API_KEY=ck_your_consumer_key_here
WORDPRESS_API_SECRET=cs_your_consumer_secret_here
WORDPRESS_API_VERSION=wc/v3

# =============================================================================
# IMPORT SETTINGS
# =============================================================================
# Product import batch size and delay
IMPORT_BATCH_SIZE=50
IMPORT_DELAY_BETWEEN_BATCHES=1000

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Maximum requests per 15 minutes per IP
REGISTER_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_MAX=10
FAILED_LOGIN_RATE_LIMIT_MAX=5

# =============================================================================
# ELASTICSEARCH CONFIGURATION (Optional - Enhanced Search Features)
# =============================================================================
# Set ELASTICSEARCH_ENABLED=true to enable advanced search capabilities
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_RETRY_TIMEOUT=5000
ELASTICSEARCH_LOG_LEVEL=warn

# =============================================================================
# GOOGLE MAPS API CONFIGURATION
# =============================================================================
# IMPORTANT: Get your API keys from Google Cloud Platform
# Setup guide: See GOOGLE_MAPS_SETUP_GUIDE.md
# Console: https://console.cloud.google.com/apis/credentials

# Server-side API key (for backend geocoding operations)
# Restrictions: IP addresses
# Required APIs: Geocoding API, Places API
GOOGLE_MAPS_SERVER_KEY=your_server_key_here

# Client-side API key (for frontend map display)
# Restrictions: HTTP referrers (domains)
# Required APIs: Maps JavaScript API, Places API
GOOGLE_MAPS_CLIENT_KEY=your_client_key_here

# Regional and language settings
# Region: ISO 3166-1 Alpha-2 country code (IN for India)
# Language: ISO 639-1 language code (en for English)
GOOGLE_MAPS_REGION=IN
GOOGLE_MAPS_LANGUAGE=en

# =============================================================================
# LOCATION SERVICE CONFIGURATION
# =============================================================================
# Session location expiry (days)
SESSION_LOCATION_EXPIRY=7

# Geocoding result cache duration (days)
# Longer duration = fewer API calls = lower costs
GEOCODING_CACHE_DURATION=30

# Maximum address search results to return
MAX_ADDRESS_SEARCH_RESULTS=5

# Default location search radius (meters)
DEFAULT_LOCATION_RADIUS=50000

# =============================================================================
# DELIVERY SETTINGS
# =============================================================================
# Warehouse processing time before shipment (days)
WAREHOUSE_PROCESSING_DAYS=1

# Exclude Sundays from delivery estimation
EXCLUDE_SUNDAYS=true

# Additional buffer for delivery estimates (days)
DELIVERY_ESTIMATE_BUFFER=0

# =============================================================================
# INVENTORY SETTINGS
# =============================================================================
# Stock reservation timeout (hours)
# Reserved stock auto-releases after this duration if order not completed
STOCK_RESERVATION_TIMEOUT=24

# Low stock alert threshold (units)
LOW_STOCK_THRESHOLD=5

# Enable split shipments (order items from multiple warehouses)
ENABLE_SPLIT_SHIPMENTS=false

# Stock synchronization frequency (seconds)
STOCK_SYNC_FREQUENCY=3600

# =============================================================================
# NOTIFICATION SERVICE CONFIGURATION (SendGrid & Twilio)
# =============================================================================

# -----------------------------------------------------------------------------
# Email Notifications (SendGrid)
# -----------------------------------------------------------------------------
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Autobacs

# -----------------------------------------------------------------------------
# SMS Notifications (Twilio)
# -----------------------------------------------------------------------------
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# -----------------------------------------------------------------------------
# Notification Settings
# -----------------------------------------------------------------------------
# Retry configuration for failed notifications
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=1000

# Enable/disable notification channels
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# =============================================================================
# ENVIRONMENT-SPECIFIC NOTES
# =============================================================================

# DEVELOPMENT ENVIRONMENT:
# - Use localhost URLs and test credentials
# - Set NODE_ENV=development
# - Use unrestricted or localhost-only API keys
# - Enable detailed logging

# PRODUCTION ENVIRONMENT:
# - Use production MongoDB Atlas cluster
# - Set NODE_ENV=production
# - Use strong, unique JWT_SECRET
# - Use restricted API keys (IP/domain)
# - Enable HTTPS/TLS
# - Set up proper CORS (FRONTEND_URL)
# - Use production email/SMS credentials
# - Enable monitoring and alerts

# =============================================================================
# QUICK START CHECKLIST
# =============================================================================
# 
# For basic functionality, configure these REQUIRED settings:
# [ ] MONGO_URI - MongoDB connection
# [ ] JWT_SECRET - Authentication security
# [ ] PORT - Server port (default: 5000)
# [ ] FRONTEND_URL - CORS configuration
#
# For location features (store locator, delivery zones):
# [ ] GOOGLE_MAPS_SERVER_KEY - Backend geocoding
# [ ] GOOGLE_MAPS_CLIENT_KEY - Frontend maps (optional)
#
# For notifications:
# [ ] SENDGRID_API_KEY - Email notifications
# [ ] TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN - SMS notifications (optional)
#
# For product import:
# [ ] WORDPRESS_SITE_URL - Source site
# [ ] WORDPRESS_API_KEY, WORDPRESS_API_SECRET - WooCommerce API
#
# For Razorpay payments:
# [ ] RAZORPAY_KEY_ID - Razorpay API key
# [ ] RAZORPAY_KEY_SECRET - Razorpay API secret
#
# =============================================================================
# RAZORPAY CONFIGURATION
# =============================================================================
# Get API keys from: https://dashboard.razorpay.com/#/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env and replace all placeholder values
#
# 3. Verify .env is in .gitignore
#
# 4. For Google Maps setup:
#    - Read GOOGLE_MAPS_SETUP_GUIDE.md
#    - Create GCP project and enable APIs
#    - Generate restricted API keys
#    - Update GOOGLE_MAPS_SERVER_KEY and GOOGLE_MAPS_CLIENT_KEY
#
# 5. Test configuration:
#    node verify-google-maps-config.js
#    node test-google-maps-integration.js
#
# 6. Start the server:
#    npm run dev
#
# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================
#
# API Keys:
# - Never commit API keys to version control
# - Use environment-specific keys
# - Restrict keys by IP (server) or domain (client)
# - Limit API access to required services only
# - Rotate keys every 90 days
# - Monitor usage for anomalies
#
# Secrets:
# - Generate strong, random JWT_SECRET
# - Use different secrets per environment
# - Store securely (use secret management tools in production)
# - Never log or expose secrets
#
# Database:
# - Use strong passwords
# - Enable authentication in production
# - Restrict IP access
# - Use SSL/TLS connections
# - Regular backups
#
# =============================================================================
# TROUBLESHOOTING
# =============================================================================
#
# Server won't start:
# - Check MONGO_URI is correct and MongoDB is running
# - Verify PORT is not in use
# - Check all required variables are set
#
# Google Maps errors:
# - Run: node verify-google-maps-config.js
# - Check API keys are valid
# - Verify APIs are enabled in GCP Console
# - Check key restrictions match your IP/domain
#
# Authentication issues:
# - Verify JWT_SECRET is set
# - Check JWT_EXPIRE format is valid (e.g., 7d, 24h)
#
# CORS errors:
# - Verify FRONTEND_URL matches frontend domain
# - Check protocol (http vs https)
# - Include port if not default (80/443)
#
# =============================================================================
# SUPPORT & DOCUMENTATION
# =============================================================================
#
# Documentation Files:
# - README.md - General project information
# - GOOGLE_MAPS_SETUP_GUIDE.md - Google Maps API setup
# - API_DOCUMENTATION.md - API endpoints reference
# - LOCATION_SERVICE_API_DOCS.md - Location features
#
# Test Scripts:
# - verify-google-maps-config.js - Configuration check
# - test-google-maps-integration.js - Integration tests
# - test-mongodb-connection.js - Database connection
#
# =============================================================================
# =============================================================================
# SOCIAL LOGIN CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# Google Login
# -----------------------------------------------------------------------------
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Optional: Override default callback URL
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# -----------------------------------------------------------------------------
# Facebook Login
# -----------------------------------------------------------------------------
# Get credentials from: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret_here
# Optional: Override default callback URL
# FACEBOOK_REDIRECT_URI=http://localhost:5000/auth/facebook/callback
