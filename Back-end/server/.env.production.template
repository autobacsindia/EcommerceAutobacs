# Production Environment Variables Template

# 🚨 IMPORTANT: Update all values before deployment!

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/autobacs?retryWrites=true&w=majority

# JWT Configuration - CHANGE THIS SECRET!
JWT_SECRET=your_very_secure_production_secret_key_here_change_immediately
JWT_EXPIRE=7d

# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://yourdomain.com

# Razorpay Production Keys
RAZORPAY_KEY_ID=your_production_razorpay_key_id
RAZORPAY_KEY_SECRET=your_production_razorpay_key_secret

# Google Maps API Keys
GOOGLE_MAPS_CLIENT_KEY=your_production_google_maps_client_key
GOOGLE_MAPS_SERVER_KEY=your_production_google_maps_server_key
GOOGLE_MAPS_REGION=IN
GOOGLE_MAPS_LANGUAGE=en

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your_production_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Autobacs India

# SMS Configuration (Twilio) - Optional
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# Notification Settings
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=1000

# Security Settings
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # requests per window

# Performance Settings
CACHE_TTL=300  # 5 minutes
MAX_CONCURRENT_REQUESTS=50

# Logging
LOG_LEVEL=info
ENABLE_ACCESS_LOGS=true

# WordPress Integration (if needed)
WORDPRESS_SITE_URL=https://your-wordpress-site.com
WORDPRESS_API_KEY=your_wordpress_api_key
WORDPRESS_API_SECRET=your_wordpress_api_secret