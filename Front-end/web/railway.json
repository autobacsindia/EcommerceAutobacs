{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile",
    "buildArgs": {
      "NEXT_PUBLIC_API_URL": "https://ecommerceautobacs-production.up.railway.app",
      "NEXT_PUBLIC_POSTHOG_KEY": "phc_yahf5rPxMDUgAwMo4uhzNwzPbhhgjvpeeE2eNmWAwt2H"
    }
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "sleepApplication": false,
    "ipv6EgressEnabled": false,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/warmup",
    "healthcheckTimeout": 30
  }
}
