{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile",
    "buildArgs": {
      "NEXT_PUBLIC_API_URL": "https://ecommerceautobacs-production.up.railway.app",
      "NEXT_PUBLIC_APP_URL": "https://ecommerceautobacs-production-8c1b.up.railway.app",
      "NODE_ENV": "production"
    }
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "sleepApplication": false,
    "ipv6EgressEnabled": false,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}