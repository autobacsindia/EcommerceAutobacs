# =============================================================================
# AUTOBACS INDIA - FRONTEND ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# IMPORTANT:
# 1. NEVER commit a real .env.local with secrets to Git.
# 2. Copy this file to .env.local and fill in your DEV values.
# 3. For production, set these in the Vercel dashboard (scoped to the
#    "Production" environment). Do NOT keep prod values in any local file.
#
# DEV vs PROD: .env.local is the DEV tier (loaded by `npm run dev`) and should
# point at your LOCAL backend. The PROD tier lives in Vercel.
# Full dev↔prod variable matrix: ../../docs/ENVIRONMENTS.md
#
# NOTE: NEXT_PUBLIC_* vars are inlined into the client bundle at BUILD time and
# are publicly visible — never put secrets in a NEXT_PUBLIC_* var.
# =============================================================================

# ── Backend API ──────────────────────────────────────────────────────────────
# Proxy target for `/api/*` rewrites (next.config.ts → ${NEXT_PUBLIC_API_URL}/api/v1/*).
# DEV: your local backend.   PROD (Vercel): https://api.autobacsindia.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Site URL ─────────────────────────────────────────────────────────────────
# Build-time baked canonical site URL (src/lib/siteUrl.ts), used for SEO/canonicals.
# DEV: http://localhost:3000   PROD (Vercel): https://autobacsindia.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── JWT (server-side ONLY — NOT public) ──────────────────────────────────────
# The edge middleware (src/middleware.ts) verifies backend-signed JWTs with this.
# CROSS-APP COUPLING: must be IDENTICAL to the backend's JWT_SECRET WITHIN a tier,
# and DIFFERENT across tiers. Rotating it means updating BOTH apps in that tier.
JWT_SECRET=must_match_backend_JWT_SECRET_for_this_tier

# ── Razorpay (public key id only) ────────────────────────────────────────────
# Must match the backend's Razorpay key tier.
# DEV: rzp_test_*   PROD: rzp_test_* until cutover → rzp_live_* at go-live.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ── Analytics (optional; leave blank to disable locally) ─────────────────────
# Use a DEV project/key locally so dev events don't pollute prod analytics.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_UI_HOST=
NEXT_PUBLIC_LOGROCKET_APP_ID=

# ── Google ───────────────────────────────────────────────────────────────────
# Maps key can be shared across tiers (restrict by HTTP referrer per env).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key
# Site verification only matters in PROD; leave blank in dev.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Build-time only ──────────────────────────────────────────────────────────
# Set ANALYZE=true to run the bundle analyzer during `next build`. Local only.
# ANALYZE=false

# ── Host-managed — DO NOT SET MANUALLY ───────────────────────────────────────
# Vercel injects these automatically; setting them by hand breaks detection.
# VERCEL, VERCEL_ENV, VERCEL_OIDC_TOKEN
